## 10. 常见错误与规范

### ❌ 禁止的模式

```typescript
// 错误1：在 async 函数中使用 new Promise(resolve => resolve(...))
async getFlightById(id: string): Promise<Flight | null> {
  return new Promise((resolve) => { // 不需要！
    resolve({ ... });
  });
}

// 正确：直接返回
async getFlightById(id: string): Promise<Flight | null> {
  return { ... };
}

// 错误2：在非 async 函数中使用 await
someMethod() { // 没有 async
  await this.service.find(); // ❌ 语法错误
}

// 正确
async someMethod() {
  await this.service.find();
}

// 错误3：缺少 @Tool/@Resource 装饰器
export class MyTool {
  myMethod(params) { ... } // ❌ 不会被自动发现
}

// 正确
export class MyTool {
  @Tool({ name: 'my_method', ... })
  async myMethod(params) { ... }
}

// 错误4：Resource 方法缺少 uri 参数
@Resource({ name: 'my_resource', uri: 'resource://x/y' })
getResource() { // ❌ 缺少 { uri } 参数
  return { contents: [...] };
}

// 正确
@Resource({ name: 'my_resource', uri: 'resource://x/y' })
getResource({ uri }: { uri: string }) {
  return { contents: [{ uri, ... }] };
}

// 错误5：FlightModule 中导入 McpModule
@Module({
  imports: [McpModule], // ❌ 循环依赖！
  providers: [FlightService, FlightTool],
})
export class FlightModule {}

// 正确：FlightTool 声明在 McpModule 中，FlightModule 只导出 FlightService
```

### ✅ 正确示例对照

```typescript
// flight.service.ts — 纯业务逻辑
@Injectable()
export class FlightService {
  async searchLowPriceFlights(params): Promise<FlightSearchResult> {
    return { success: true, flights: [...], totalCount: 1, message: 'OK' };
  }
}

// flight.tool.ts — MCP 工具层，注入 FlightService
@Injectable()
export class FlightTool {
  constructor(private readonly flightService: FlightService) {}

  @Tool({ name: 'search_low_price_flights', parameters: MySchema })
  async search(params: MyParams) {
    const result = await this.flightService.searchLowPriceFlights(params);
    return this.buildFlightSearchResponse(result);
  }
}

// mcp.module.ts — 注册 MCP Server
@Module({
  imports: [McpModule.forRoot({ ... }), FlightModule],
  providers: [FlightTool],
  exports: [McpModule, FlightModule],
})
export class McpModule {}

// app.module.ts — 应用根模块
@Module({
  imports: [McpModule], // FlightService 通过 McpModule 间接导出
})
export class AppModule {}
```

