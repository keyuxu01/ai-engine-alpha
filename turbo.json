{
  "$schema": "https://turborepo.dev/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"],
      "env": [
        "API_URL",
        "NEXT_PUBLIC_API_URL",
        "QWEN_LLM_API_KEY",
        "QWEN_CODER_TURBO_MODEL_NAME",
        "QWEN_CODER_TURBO_MODEL_BASE_URL",
        "PROJECT_ROOT",
        "APP_ENV",
        "QWEN_CODER_PLUS_MODEL_NAME",
        "AMAP_MAPS_STREAMABLEHTTP_URL",
        "ALLOWED_FS_PATHS"
      ]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "test": {
      "cache": false,
      "dependsOn": ["^test"]
    }
  }
}
